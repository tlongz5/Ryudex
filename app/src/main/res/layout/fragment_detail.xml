<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        tools:context=".ui.views.fragment.DetailFragment">

        <ImageView
            android:id="@+id/imgBanner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:scaleType="centerCrop"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:src="@drawable/img_bgr" />

        <View
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="#20000000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mcvCover"
            android:layout_width="120dp"
            android:layout_height="160dp"
            app:cardCornerRadius="16dp"
            android:layout_marginTop="@dimen/margin_medium2"
            android:layout_marginStart="@dimen/padding_medium"
            app:layout_constraintBottom_toBottomOf="@+id/imgBanner"
            app:layout_constraintStart_toStartOf="@+id/imgBanner"
            app:layout_constraintTop_toTopOf="@+id/imgBanner"
            app:strokeColor="@color/white"
            app:strokeWidth="2dp">

            <ImageView
                android:id="@+id/imgCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:layout_marginStart="@dimen/margin_small2"
            android:layout_marginEnd="@dimen/margin_small2"
            app:layout_constraintBottom_toBottomOf="@+id/mcvCover"
            app:layout_constraintEnd_toEndOf="@+id/imgBanner"
            app:layout_constraintStart_toEndOf="@+id/mcvCover"
            app:layout_constraintTop_toTopOf="@+id/mcvCover">

            <TextView
                android:id="@+id/tvTitle"
                android:text="title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="@dimen/text_title_small"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgAuthor"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_bookmark"
                    app:tint="#DFE0E0" />

                <TextView
                    android:id="@+id/tvAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_medium"
                    android:text="author"
                    android:textColor="#DFE0E0"
                    android:textSize="@dimen/text_description"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="horizontal"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRead"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Read"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_title_medium"
                    app:cornerRadius="20dp"
                    app:backgroundTint="@color/blue_medium"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="@dimen/padding_vertical_medium" />

                <ImageView
                    android:id="@+id/btnSave"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="@dimen/margin_small2"
                    android:layout_gravity="center"/>

            </LinearLayout>

            <Spinner
                android:id="@+id/languageSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_small"
                android:paddingVertical="@dimen/padding_small"
                android:paddingHorizontal="@dimen/padding_horizontal_small"
                android:background="@drawable/bg_tag" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_medium"
            android:animateLayoutChanges="true"
            android:background="@drawable/custom_description"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/imgBanner">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:layout_marginBottom="@dimen/margin_small"
                android:padding="@dimen/padding_small"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/t"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Description"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_title_medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/margin_small2"
                    android:text="More"
                    android:textColor="@color/blue_medium"
                    android:textSize="@dimen/text_title_medium"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/margin_medium"
                android:ellipsize="end"
                android:maxLines="5"
                android:text="des"
                android:textColor="@color/black"
                android:textSize="@dimen/text_description" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small2"
            android:layout_marginStart="@dimen/margin_small2"
            android:layout_marginEnd="@dimen/margin_small2"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chapter"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_title_medium"/>

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/img_bgr" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/btnSort"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_down"
                    app:tint="#787878" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_chapter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/margin_small2"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout2">

            <TextView
                android:id="@+id/text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Related Manga"
                android:textSize="@dimen/text_title_medium"
                android:textStyle="bold"
                tools:layout_editor_absoluteX="108dp" />

            <TextView
                android:id="@+id/tvShowAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_small2"
                android:text="Show All"
                android:textColor="@color/blue_medium"
                android:textSize="@dimen/text_title_medium"
                android:textStyle="bold" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcv_related_manga"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:layout_marginStart="@dimen/margin_small2"
            android:layout_marginEnd="@dimen/margin_small2"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout3" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>

